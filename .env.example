# Copy to ".env" and fill values. Restart dev server after any change.
#
# Admin panel (/admin/login) — use a REAL email (must contain @) and password on one line each:
# VITE_ADMIN_EMAIL=you@example.com
# VITE_ADMIN_PASSWORD=your-secure-password
#
# Supabase (registration + gym_users)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# After custom SMTP: add the same URL in Supabase → Authentication → URL Configuration → Redirect URLs
# VITE_SUPABASE_EMAIL_REDIRECT_TO=http://localhost:5173/login
# VITE_SUPABASE_EMAIL_REDIRECT_TO=https://your-domain.com/login
